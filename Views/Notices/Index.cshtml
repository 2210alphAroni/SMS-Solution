@model List<SchoolManagementSystem.Models.Notice>
@{
    ViewData["Title"] = "Notice Board";
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-bullhorn me-2 text-primary"></i>Notice Board</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li><li class="breadcrumb-item active">Notices</li></ol></nav>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
    {
        <a href="/Notices/Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Post Notice</a>
    }
</div>

@if (Model.Any())
{
    <!-- Pinned Notices -->
    @if (Model.Any(n => n.IsPinned))
    {
        <div class="mb-4">
            <h6 class="text-muted text-uppercase small fw-bold mb-3"><i class="fas fa-thumbtack me-2"></i>Pinned Notices</h6>
            @foreach (var notice in Model.Where(n => n.IsPinned))
            {
                <div class="card mb-3 border-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge @GetCategoryBadge(notice.Category)">@notice.Category</span>
                                    <i class="fas fa-thumbtack text-warning small"></i>
                                </div>
                                <h5 class="fw-bold mb-2">@notice.Title</h5>
                                <p class="text-muted mb-2">@notice.Content</p>
                                <small class="text-muted"><i class="fas fa-clock me-1"></i>@notice.CreatedAt.ToString("dd MMM yyyy, hh:mm tt") · Expires @notice.ExpiryDate.ToString("dd MMM yyyy")</small>
                            </div>
                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                            {
                                <div class="d-flex gap-1 ms-3">
                                    <a href="/Notices/Edit/@notice.Id" class="btn btn-sm btn-outline-secondary"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Delete" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@notice.Id"/>
                                        <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete this notice?"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- All Notices -->
    <div class="row g-3">
        @foreach (var notice in Model.Where(n => !n.IsPinned))
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @GetCategoryBadge(notice.Category)">@notice.Category</span>
                            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                            {
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown"><i class="fas fa-ellipsis-v"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="/Notices/Edit/@notice.Id"><i class="fas fa-edit me-2"></i>Edit</a></li>
                                        <li>
                                            <form asp-action="Delete" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@notice.Id"/>
                                                <button type="submit" class="dropdown-item text-danger" data-confirm="Delete this notice?"><i class="fas fa-trash me-2"></i>Delete</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                        </div>
                        <h6 class="fw-bold mb-2">@notice.Title</h6>
                        <p class="text-muted small mb-3" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">@notice.Content</p>
                        <small class="text-muted"><i class="fas fa-calendar me-1"></i>@notice.CreatedAt.ToString("dd MMM yyyy")</small>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5 text-muted card"><div class="card-body">
        <i class="fas fa-bullhorn fa-3x mb-3 d-block opacity-25"></i>
        <h5>No notices published yet</h5>
        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        {
            <a href="/Notices/Create" class="btn btn-primary mt-2"><i class="fas fa-plus me-2"></i>Post First Notice</a>
        }
    </div></div>
}

@functions {
    string GetCategoryBadge(string cat) => cat switch {
        "Emergency" => "bg-danger",
        "Exam" => "bg-warning text-dark",
        "Holiday" => "bg-success",
        "Event" => "bg-info",
        _ => "bg-primary"
    };
}
