@model List<SchoolManagementSystem.Models.SubscriptionPlan>
@{
    ViewData["Title"] = "EduManage Pro - Modern School Management System";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>
<!-- Navbar -->
<nav class="navbar-public">
    <div class="container-fluid d-flex align-items-center">
        <a href="/" class="brand-link text-decoration-none text-dark fw-bold fs-5">
            <i class="fas fa-graduation-cap text-primary me-2 fs-4"></i>EduManage Pro
        </a>
        <div class="ms-auto d-flex align-items-center gap-3">
            <a href="#about" class="text-secondary text-decoration-none d-none d-md-inline">About</a>
            <a href="#contact" class="text-secondary text-decoration-none d-none d-md-inline">Contact</a>
            <a href="#features" class="text-secondary text-decoration-none d-none d-md-inline">Features</a>
            <a href="#pricing" class="text-secondary text-decoration-none d-none d-md-inline">Pricing</a>
            <a href="/Account/Login" class="btn btn-outline-primary">Sign In</a>
            <a href="/Account/Register" class="btn btn-primary">Get Started Free</a>
        </div>
    </div>
</nav>

<!-- Hero -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-badge"><i class="fas fa-star"></i> Trusted by 500+ Schools in Bangladesh</div>
                <h1 class="hero-title">Complete <span>School Management</span> Solution</h1>
                <p class="hero-subtitle">Manage students, teachers, attendance, fees, exams, and more — all in one powerful SaaS platform. Built for Bangladeshi schools.</p>
                <div class="hero-cta">
                    <a href="/Account/Register" class="btn-hero-primary">Start Free Trial <i class="fas fa-arrow-right ms-2"></i></a>
                    <a href="#features" class="btn-hero-secondary"><i class="fas fa-play-circle me-2"></i>See Features</a>
                </div>
                <div class="mt-4 d-flex gap-4 flex-wrap">
                    <div class="text-white-50 small"><i class="fas fa-check text-success me-1"></i>No credit card required</div>
                    <div class="text-white-50 small"><i class="fas fa-check text-success me-1"></i>30-day free trial</div>
                    <div class="text-white-50 small"><i class="fas fa-check text-success me-1"></i>Setup in 5 minutes</div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="rounded-4 overflow-hidden shadow-lg" style="background:rgba(255,255,255,.1); padding:24px; backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.2);">
                    <div class="row g-3">
                        @foreach(var item in new[]{
                            ("fa-user-graduate","1,284","Total Students","text-info"),
                            ("fa-chalkboard-teacher","84","Teachers","text-success"),
                            ("fa-clipboard-check","97.3%","Attendance Today","text-warning"),
                            ("fa-money-bill-wave","৳2.4L","Fee Collected","text-primary")
                        })
                        {
                            <div class="col-6">
                                <div class="p-3 rounded-3" style="background:rgba(255,255,255,.1)">
                                    <i class="fas @item.Item1 @item.Item4 mb-2"></i>
                                    <div class="text-white fw-bold fs-5">@item.Item2</div>
                                    <div class="text-white-50 small">@item.Item3</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="py-4 bg-white border-bottom">
    <div class="container">
        <div class="row text-center g-4">
            @foreach(var stat in new[]{("500+","Schools Registered"),("50,000+","Students Managed"),("99.9%","Uptime SLA"),("24/7","Customer Support")})
            {
                <div class="col-6 col-md-3">
                    <div class="fw-bold fs-3 text-primary">@stat.Item1</div>
                    <div class="text-muted small">@stat.Item2</div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Features -->
<section class="features-section" id="features">
    <div class="container">
        <p class="text-primary fw-bold text-center text-uppercase small tracking-wide mb-2">FEATURES</p>
        <h2 class="section-title">Everything Your School Needs</h2>
        <p class="section-subtitle">From daily attendance to annual reports, we've got every aspect of school management covered.</p>
        <div class="row g-4">
            @foreach(var feature in new[]{
                ("fa-user-graduate","Student Management","Complete student profiles, admission management, parent linkage, and document management."),
                ("fa-chalkboard-teacher","Teacher Management","Employee records, qualifications, class assignments, and salary management."),
                ("fa-clipboard-check","Smart Attendance","Take attendance class-wise, get instant reports, and track trends over time."),
                ("fa-file-alt","Exams & Results","Create exam schedules, enter marks, auto-calculate grades and generate report cards."),
                ("fa-money-bill-wave","Fee Management","Flexible fee structures, collect payments, generate receipts, and track dues."),
                ("fa-chart-bar","Reports & Analytics","Detailed reports for attendance, fees, results and school performance."),
                ("fa-bullhorn","Notice Board","Post announcements, events, and circulars for students, parents, and teachers."),
                ("fa-book","Library System","Manage books, issue/return tracking, fine management, and catalog search."),
                ("fa-calendar-alt","Timetable Builder","Create and manage class timetables, room allocation, and period scheduling."),
                ("fa-mobile-alt","Parent Portal","Parents can view their child's attendance, results, fees, and notices."),
                ("fa-shield-alt","Multi-Tenant SaaS","Each school gets its own secure, isolated environment with custom subdomain."),
                ("fa-cloud","Cloud-Based","Access from anywhere, automatic backups, and no server maintenance required.")
            })
            {
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas @feature.Item1"></i></div>
                        <h5 class="feature-title">@feature.Item2</h5>
                        <p class="feature-desc">@feature.Item3</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Pricing -->
<section class="pricing-section" id="pricing">
    <div class="container">
        <p class="text-primary fw-bold text-center text-uppercase small mb-2">PRICING</p>
        <h2 class="section-title">Simple, Transparent Pricing</h2>
        <p class="section-subtitle">Choose the plan that fits your school. Upgrade anytime as you grow.</p>
        <div class="row g-4 justify-content-center">
            @if (Model != null)
            {
                @foreach (var plan in Model.Where(p => p.IsActive))
                {
                    <div class="col-md-6 col-lg-3">
                        <div class="pricing-card @(plan.Name == "Professional" ? "popular" : "")">
                            @if (plan.Name == "Professional")
                            {
                                <div class="popular-badge"><i class="fas fa-star me-1"></i>Most Popular</div>
                            }
                            <div class="pricing-name">@plan.Name</div>
                            <div class="pricing-price">
                                @if (plan.MonthlyPrice == 0)
                                {
                                    <span>Free</span>
                                }
                                else
                                {
                                    <span>৳@plan.MonthlyPrice.ToString("N0")</span><span>/month</span>
                                }
                            </div>
                            <p class="text-muted small mt-2">@plan.Description</p>
                            <ul class="pricing-features">
                                <li><i class="fas fa-check"></i>Up to @(plan.MaxStudents == 999999 ? "Unlimited" : plan.MaxStudents.ToString()) students</li>
                                <li><i class="fas fa-check"></i>@(plan.MaxTeachers == 999999 ? "Unlimited" : plan.MaxTeachers.ToString()) teachers</li>
                                @foreach (var feature in plan.Features.Take(4))
                                {
                                    <li><i class="fas fa-check"></i>@feature</li>
                                }
                            </ul>
                            <a href="/Account/Register" class="btn @(plan.Name == "Professional" ? "btn-primary" : "btn-outline-primary") w-100">
                                @(plan.MonthlyPrice == 0 ? "Get Started Free" : "Start Free Trial")
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                @foreach(var plan in new[]{("Free","0","50 Students"),("Basic","999","300 Students"),("Professional","2499","1000 Students"),("Enterprise","4999","Unlimited")})
                {
                    <div class="col-md-6 col-lg-3">
                        <div class="pricing-card">
                            <div class="pricing-name">@plan.Item1</div>
                            <div class="pricing-price">@(plan.Item2 == "0" ? "Free" : $"৳{plan.Item2}")<span>@(plan.Item2 == "0" ? "" : "/month")</span></div>
                            <a href="/Account/Register" class="btn btn-outline-primary w-100 mt-3">Get Started</a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:linear-gradient(135deg,#4f46e5,#7c3aed)">
    <div class="container text-center text-white py-4">
        <h2 class="fw-bold mb-3">Ready to Transform Your School?</h2>
        <p class="mb-4 opacity-75">Join hundreds of schools already using EduManage Pro</p>
        <a href="/Account/Register" class="btn-hero-primary btn">Create Your School Account <i class="fas fa-arrow-right ms-2"></i></a>
    </div>
</section>

<!-- Footer -->
<footer class="bg-dark text-white py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="fw-bold fs-5 mb-3"><i class="fas fa-graduation-cap text-primary me-2"></i>EduManage Pro</div>
                <p class="text-white-50 small">Bangladesh's leading school management SaaS platform. Empowering educators with technology.</p>
            </div>
            <div class="col-md-2">
                <div class="fw-bold mb-3">Product</div>
                <ul class="list-unstyled text-white-50 small">
                    <li><a href="#features" class="text-white-50 text-decoration-none">Features</a></li>
                    <li><a href="#pricing" class="text-white-50 text-decoration-none">Pricing</a></li>
                    <li><a href="/Account/Register" class="text-white-50 text-decoration-none">Get Started</a></li>
                </ul>
            </div>
            <div class="col-md-2">
                <div class="fw-bold mb-3">Company</div>
                <ul class="list-unstyled text-white-50 small">
                    <li><a href="/Home/Privacy" class="text-white-50 text-decoration-none">Privacy Policy</a></li>
                    <li><a href="/Home/Terms" class="text-white-50 text-decoration-none">Terms</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <div class="fw-bold mb-3">Contact Us</div>
                <div class="text-white-50 small">
                    <p><i class="fas fa-envelope me-2"></i>nabinuri80@gmail.com</p>
                    <p><i class="fas fa-phone me-2"></i>+880 1727687830</p>
                    <p><i class="fas fa-map-marker-alt me-2"></i>Dhaka, Bangladesh</p>
                </div>
            </div>
        </div>
        <hr class="border-secondary mt-4"/>
        <div class="d-flex flex-wrap justify-content-between align-items-center text-white-50 small">
            <span>© @DateTime.Now.Year EduManage Pro. All rights reserved.</span>
            <span>Made with <i class="fas fa-heart text-danger"></i> in Bangladesh</span>
            <span>Developed by: <a href="https://roniportfolio.onrender.com" target="_blank">Nabinur Islam Roni</a></span>
        </div>
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
