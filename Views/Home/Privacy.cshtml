    ViewData["Title"] = "Privacy Policy";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Privacy Policy - EduManage Pro</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body style="background:var(--bg-body)">
<nav class="navbar-public"><div class="container-fluid d-flex align-items-center">
    <a href="/" class="fw-bold fs-5 text-dark text-decoration-none"><i class="fas fa-graduation-cap text-primary me-2"></i>EduManage Pro</a>
    <a href="/" class="ms-auto btn btn-outline-primary btn-sm">← Back to Home</a>
</div></nav>
<div class="container py-5" style="max-width:800px;">
    <h1 class="fw-bold mb-4">Privacy Policy</h1>
    <p class="text-muted">Last updated: January 1, 2025</p>
    <div class="card"><div class="card-body p-4">
        <h5>1. Information We Collect</h5>
        <p>We collect information you provide directly to us, such as when you create a school account, register students, or contact us for support.</p>
        <h5>2. How We Use Your Information</h5>
        <p>We use the information we collect to provide, maintain, and improve our services, process transactions, and send important notices.</p>
        <h5>3. Data Security</h5>
        <p>We implement industry-standard security measures including SSL encryption, bcrypt password hashing, and MongoDB Atlas security features to protect your data.</p>
        <h5>4. Data Isolation</h5>
        <p>Each school's data is completely isolated from other schools. Your students' records, fees, and academic data are never shared with other tenants.</p>
        <h5>5. Contact Us</h5>
        <p>If you have questions about this Privacy Policy, contact us at <a href="mailto:privacy@edumanagepro.com">privacy@edumanagepro.com</a>.</p>
    </div></div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
