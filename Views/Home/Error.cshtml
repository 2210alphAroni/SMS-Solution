@{
    ViewData["Title"] = "Error";
}
<div class="min-vh-100 d-flex align-items-center justify-content-center">
    <div class="text-center">
        <div class="display-1 fw-bold text-muted mb-3">⚠️</div>
        <h2 class="fw-bold mb-3">Something went wrong</h2>
        <p class="text-muted mb-4">An error occurred while processing your request. Please try again.</p>
        <a href="/Dashboard" class="btn btn-primary me-2"><i class="fas fa-home me-2"></i>Go to Dashboard</a>
        <button onclick="history.back()" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Go Back</button>
    </div>
</div>
