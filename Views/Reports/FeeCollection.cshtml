@model List<SchoolManagementSystem.Models.FeePayment>
@{
    ViewData["Title"] = "Fee Collection Report";
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-money-bill-wave me-2 text-primary"></i>Fee Collection Report</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Reports">Reports</a></li>
            <li class="breadcrumb-item active">Fee Collection</li>
        </ol></nav>
    </div>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary d-print-none"><i class="fas fa-print me-2"></i>Print</button>
    </div>
</div>

<div class="card mb-4 d-print-none">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3"><label class="form-label">From Date</label><input name="from" type="date" class="form-control" value="@(ViewBag.From ?? DateTime.Today.AddDays(-30))" /></div>
            <div class="col-md-3"><label class="form-label">To Date</label><input name="to" type="date" class="form-control" value="@(ViewBag.To ?? DateTime.Today)" /></div>
            <div class="col-md-3"><label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Paid">Paid</option>
                    <option value="Partial">Partial</option>
                    <option value="Unpaid">Unpaid</option>
                </select>
            </div>
            <div class="col-md-3"><button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-2"></i>Apply Filter</button></div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon green"><i class="fas fa-check-circle"></i></div><div>
        <div class="stat-value">৳@Model.Sum(p => p.PaidAmount).ToString("N0")</div>
        <div class="stat-label">Total Collected</div>
    </div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon red"><i class="fas fa-exclamation-circle"></i></div><div>
        <div class="stat-value">৳@Model.Sum(p => p.DueAmount).ToString("N0")</div>
        <div class="stat-label">Total Due</div>
    </div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon blue"><i class="fas fa-receipt"></i></div><div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-label">Transactions</div>
    </div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon purple"><i class="fas fa-percentage"></i></div><div>
        @{ var total = Model.Sum(p => p.TotalAmount); var collected = Model.Sum(p => p.PaidAmount); }
        <div class="stat-value">@(total > 0 ? (collected / total * 100).ToString("F1") : "0")%</div>
        <div class="stat-label">Collection Rate</div>
    </div></div></div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr><th>#</th><th>RECEIPT NO</th><th>STUDENT ID</th><th>TOTAL</th><th>PAID</th><th>DUE</th><th>METHOD</th><th>DATE</th><th>STATUS</th></tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var p in Model.OrderByDescending(p => p.PaymentDate))
                {
                    <tr>
                        <td class="text-muted">@i++</td>
                        <td><code class="text-primary small">@p.ReceiptNo</code></td>
                        <td class="small text-muted">@p.StudentId</td>
                        <td>৳@p.TotalAmount.ToString("N0")</td>
                        <td class="text-success fw-semibold">৳@p.PaidAmount.ToString("N0")</td>
                        <td class="@(p.DueAmount > 0 ? "text-danger fw-semibold" : "text-muted")">৳@p.DueAmount.ToString("N0")</td>
                        <td><span class="badge bg-light text-dark small">@p.PaymentMethod</span></td>
                        <td class="small">@p.PaymentDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge @(p.Status=="Paid"?"bg-success":p.Status=="Partial"?"bg-warning text-dark":"bg-danger")">@p.Status</span></td>
                    </tr>
                }
            </tbody>
            <tfoot class="fw-bold">
                <tr class="table-light">
                    <td colspan="3">TOTAL</td>
                    <td>৳@Model.Sum(p => p.TotalAmount).ToString("N0")</td>
                    <td class="text-success">৳@Model.Sum(p => p.PaidAmount).ToString("N0")</td>
                    <td class="text-danger">৳@Model.Sum(p => p.DueAmount).ToString("N0")</td>
                    <td colspan="3"></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
