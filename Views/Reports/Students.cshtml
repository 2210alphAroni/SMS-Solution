@model List<SchoolManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Student Report";
    var classDict = ViewBag.ClassDict as Dictionary<string, string> ?? new();
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-user-graduate me-2 text-primary"></i>Student Report</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Reports">Reports</a></li>
            <li class="breadcrumb-item active">Students</li>
        </ol></nav>
    </div>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary d-print-none">
            <i class="fas fa-print me-2"></i>Print
        </button>
        <a href="/Reports/Students?export=excel" class="btn btn-outline-success d-print-none">
            <i class="fas fa-file-excel me-2"></i>Export Excel
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon purple"><i class="fas fa-users"></i></div><div><div class="stat-value">@Model.Count</div><div class="stat-label">Total Students</div></div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon green"><i class="fas fa-check"></i></div><div><div class="stat-value">@Model.Count(s => s.Status == "Active")</div><div class="stat-label">Active</div></div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon blue"><i class="fas fa-male"></i></div><div><div class="stat-value">@Model.Count(s => s.Gender == "Male")</div><div class="stat-label">Male</div></div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon orange"><i class="fas fa-female"></i></div><div><div class="stat-value">@Model.Count(s => s.Gender == "Female")</div><div class="stat-label">Female</div></div></div></div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>#</th>
                    <th>NAME</th>
                    <th>ADMISSION NO</th>
                    <th>CLASS</th>
                    <th>SECTION</th>
                    <th>GENDER</th>
                    <th>PHONE</th>
                    <th>ADMITTED ON</th>
                    <th>STATUS</th>
                </tr>
            </thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="text-muted">@i++</td>
                        <td class="fw-semibold">@s.FullName</td>
                        <td><code>@s.AdmissionNo</code></td>
                        <td>@(classDict.GetValueOrDefault(s.ClassId ?? "", "-"))</td>
                        <td>@(s.Section ?? "-")</td>
                        <td>@(s.Gender ?? "-")</td>
                        <td class="small">@(s.Phone ?? "-")</td>
                        <td class="small">@s.AdmissionDate</td>
                        <td><span class="badge @(s.Status == "Active" ? "badge-status-active" : "badge-status-inactive")">@s.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
@@media print {
    .d-print-none { display: none !important; }
    .stat-card { break-inside: avoid; }
}
</style>
