@model SchoolManagementSystem.Models.Class
@{
    ViewData["Title"] = "Edit Class";
    var teachers = ViewBag.Teachers as List<SchoolManagementSystem.Models.Teacher> ?? new();
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-edit me-2 text-primary"></i>Edit Class</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Classes">Classes</a></li>
            <li class="breadcrumb-item active">Edit - @Model.Name</li>
        </ol></nav>
    </div>
</div>
<div class="row justify-content-center">
    <div class="col-lg-8">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TenantId" />
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-info-circle me-2 text-primary"></i>Class Information</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-8"><label class="form-label">Class Name *</label><input asp-for="Name" class="form-control" required /></div>
                        <div class="col-md-4"><label class="form-label">Display Order</label><input asp-for="Order" type="number" class="form-control" /></div>
                    </div>
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-layer-group me-2 text-primary"></i>Sections</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addSection()"><i class="fas fa-plus me-1"></i>Add Section</button>
                </div>
                <div class="card-body" id="sectionsContainer">
                    @for (int i = 0; i < Model.Sections.Count; i++)
                    {
                        <div class="row g-2 align-items-end mb-3 border-bottom pb-3 section-row">
                            @* ফিক্স: যেহেতু Section মডেলে Id নেই, তাই আমরা এই হিডেন ইনপুটটি সরিয়ে দিয়েছি *@
                            <div class="col-md-3"><label class="form-label small">Section Name</label>
                                <input type="text" class="form-control form-control-sm" name="Sections[@i].Name" value="@Model.Sections[i].Name" required />
                            </div>
                            <div class="col-md-5"><label class="form-label small">Class Teacher</label>
                                <select class="form-select form-select-sm" name="Sections[@i].ClassTeacherId">
                                    <option value="">-- No Teacher --</option>
                                    @foreach (var t in teachers)
                                    { <option value="@t.Id" selected="@(Model.Sections[i].ClassTeacherId == t.Id ? "selected" : null)">@t.FullName</option> }
                                </select>
                            </div>
                            <div class="col-md-3"><label class="form-label small">Capacity</label>
                                <input type="number" class="form-control form-control-sm" name="Sections[@i].Capacity" value="@Model.Sections[i].Capacity" />
                            </div>
                            <div class="col-md-1 text-end">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.section-row').remove()"><i class="fas fa-times"></i></button>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="d-flex gap-3 justify-content-end">
                <a href="/Classes" class="btn btn-outline-secondary"><i class="fas fa-times me-2"></i>Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
            </div>
        </form>
    </div>
</div>
<script>
var sectionIndex = @Model.Sections.Count;
// ফিক্স: শিক্ষক তালিকার অপশনগুলো তৈরির নিয়মটি সহজ করা হয়েছে
var teacherOptions = '<option value="">-- No Teacher --</option>' + 
    '@Html.Raw(string.Join("", teachers.Select(t => $"<option value='{t.Id}'>{t.FullName}</option>")))';

function addSection() {
    const container = document.getElementById('sectionsContainer');
    const div = document.createElement('div');
    div.className = 'row g-2 align-items-end mb-3 border-bottom pb-3 section-row';
    div.innerHTML = `<div class="col-md-3"><label class="form-label small">Section Name</label><input type="text" class="form-control form-control-sm" name="Sections[${sectionIndex}].Name" required /></div>
        <div class="col-md-5"><label class="form-label small">Class Teacher</label><select class="form-select form-select-sm" name="Sections[${sectionIndex}].ClassTeacherId">${teacherOptions}</select></div>
        <div class="col-md-3"><label class="form-label small">Capacity</label><input type="number" class="form-control form-control-sm" name="Sections[${sectionIndex}].Capacity" value="40" /></div>
        <div class="col-md-1 text-end"><button type="button" class="btn btn-sm btn-outline-danger" onclick="this.closest('.section-row').remove()"><i class="fas fa-times"></i></button></div>`;
    container.appendChild(div);
    sectionIndex++;
}
</script>