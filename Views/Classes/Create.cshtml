@model SchoolManagementSystem.Models.Class
@{
    ViewData["Title"] = "Create Class";
    var teachers = ViewBag.Teachers as List<SchoolManagementSystem.Models.Teacher> ?? new();
    var academicYears = ViewBag.AcademicYears as List<SchoolManagementSystem.Models.AcademicYear> ?? new();
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-plus-circle me-2 text-primary"></i>Create New Class</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Classes">Classes</a></li>
            <li class="breadcrumb-item active">Create</li>
        </ol></nav>
    </div>
</div>
<div class="row justify-content-center">
    <div class="col-lg-8">
        <form asp-action="Create" method="post" id="classForm">
            @Html.AntiForgeryToken()
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-info-circle me-2 text-primary"></i>Class Information</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Class Name *</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Class 1, Grade 10, SSC" required/>
                            <div class="form-text">e.g., Class 1, Class 2, ... Class 10, SSC, HSC</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Order / Sort</label>
                            <input asp-for="Order" type="number" class="form-control" placeholder="1" min="0"/>
                            <div class="form-text">For display ordering</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Academic Year</label>
                            <select asp-for="AcademicYearId" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach (var y in academicYears)
                                {
                                    <option value="@y.Id" selected="@y.IsCurrentYear">@y.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="fas fa-layer-group me-2 text-primary"></i>Sections</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addSection()">
                        <i class="fas fa-plus me-1"></i>Add Section
                    </button>
                </div>
                <div class="card-body">
                    <div id="sectionsContainer">
                        <div class="text-muted small text-center py-3" id="noSectionsMsg">
                            No sections added. Click "Add Section" to add sections (A, B, C...).
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end">
                <a href="/Classes" class="btn btn-outline-secondary"><i class="fas fa-times me-2"></i>Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Class</button>
            </div>
        </form>
    </div>
</div>

<script>
var sectionIndex = 0;
// ফিক্সড লাইন: আমরা C# এর string.Join ব্যবহার করে সরাসরি অপশনগুলো তৈরি করেছি
var teacherOptions = `<option value="">-- No Teacher --</option>` + 
    '@Html.Raw(string.Join("", teachers.Select(t => $"<option value='{t.Id}'>{t.FullName}</option>")))';

function addSection() {
    document.getElementById('noSectionsMsg')?.remove();
    const container = document.getElementById('sectionsContainer');
    const div = document.createElement('div');
    div.className = 'row g-3 align-items-end mb-3 border-bottom pb-3 section-row';
    div.innerHTML = `
        <div class="col-md-3">
            <label class="form-label small">Section Name *</label>
            <input type="text" class="form-control form-control-sm" name="Sections[${sectionIndex}].Name"
                   placeholder="A, B, C..." required maxlength="5"/>
        </div>
        <div class="col-md-5">
            <label class="form-label small">Class Teacher</label>
            <select class="form-select form-select-sm" name="Sections[${sectionIndex}].ClassTeacherId">
                ${teacherOptions}
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small">Capacity</label>
            <input type="number" class="form-control form-control-sm" name="Sections[${sectionIndex}].Capacity" value="40" min="1" max="200"/>
        </div>
        <div class="col-md-1 text-end">
            <button type="button" class="btn btn-sm btn-outline-danger"
                    onclick="this.closest('.section-row').remove()">
                <i class="fas fa-times"></i>
            </button>
        </div>`;
    container.appendChild(div);
    sectionIndex++;
}
</script>