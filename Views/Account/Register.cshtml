@model SchoolManagementSystem.ViewModels.RegisterTenantViewModel
@{
    ViewData["Title"] = "Register School";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Register Your School - EduManage Pro</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body style="background:var(--bg-body)">
<div class="min-vh-100 py-5">
    <div class="container">
        <div class="text-center mb-4">
            <a href="/" class="text-decoration-none">
                <span class="fw-bold fs-4 text-primary"><i class="fas fa-graduation-cap me-2"></i>EduManage Pro</span>
            </a>
            <h2 class="mt-3 fw-bold">Create Your School Account</h2>
            <p class="text-muted">Start your 30-day free trial. No credit card required.</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0" style="border-radius:16px;">
                    <div class="card-body p-4 p-md-5">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-circle me-2"></i>@Html.ValidationSummary(true)
                            </div>
                        }
                        <form asp-action="Register" method="post">
                            @Html.AntiForgeryToken()

                            <div class="form-section">
                                <div class="form-section-title"><i class="fas fa-school"></i>School Information</div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="SchoolName" class="form-label">School Name <span class="text-danger">*</span></label>
                                        <input asp-for="SchoolName" class="form-control" placeholder="Green Valley High School"/>
                                        <span asp-validation-for="SchoolName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Subdomain" class="form-label">School Code <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input asp-for="Subdomain" class="form-control" placeholder="greenvalley" id="subdomainInput" oninput="updatePreview()"/>
                                            <span class="input-group-text text-muted small">.edumanagepro.com</span>
                                        </div>
                                        <div class="form-text" id="urlPreview">Your school URL will be: <strong>greenvalley.edumanagepro.com</strong></div>
                                        <span asp-validation-for="Subdomain" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="PrincipalName" class="form-label">Principal's Name <span class="text-danger">*</span></label>
                                        <input asp-for="PrincipalName" class="form-control" placeholder="Mr. John Smith"/>
                                        <span asp-validation-for="PrincipalName" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Phone" class="form-label">Phone Number <span class="text-danger">*</span></label>
                                        <input asp-for="Phone" class="form-control" placeholder="+880 1700-000000"/>
                                        <span asp-validation-for="Phone" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-8">
                                        <label asp-for="Address" class="form-label">Address <span class="text-danger">*</span></label>
                                        <input asp-for="Address" class="form-control" placeholder="123 School Road"/>
                                        <span asp-validation-for="Address" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-4">
                                        <label asp-for="City" class="form-label">City</label>
                                        <input asp-for="City" class="form-control" placeholder="Dhaka"/>
                                    </div>
                                </div>
                            </div>

                            <div class="form-section">
                                <div class="form-section-title"><i class="fas fa-user-shield"></i>Admin Account</div>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="Email" class="form-label">Admin Email <span class="text-danger">*</span></label>
                                        <input asp-for="Email" class="form-control" type="email" placeholder="admin@yourschool.com"/>
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Password" class="form-label">Password <span class="text-danger">*</span></label>
                                        <input asp-for="Password" class="form-control" type="password" placeholder="Min. 8 characters"/>
                                        <span asp-validation-for="Password" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password"/>
                                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="form-check">
                                    <input asp-for="AgreeToTerms" class="form-check-input" type="checkbox" required/>
                                    <label class="form-check-label small">
                                        I agree to the <a href="/Home/Terms" target="_blank" class="text-primary">Terms of Service</a> and
                                        <a href="/Home/Privacy" target="_blank" class="text-primary">Privacy Policy</a>
                                    </label>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-3 fw-semibold">
                                <i class="fas fa-rocket me-2"></i>Create School Account
                            </button>
                        </form>
                        <hr class="my-4"/>
                        <p class="text-center text-muted small">Already have an account? <a href="/Account/Login" class="text-primary fw-semibold">Sign in here</a></p>
                    </div>
                </div>
                <div class="text-center mt-3">
                    <div class="d-flex justify-content-center gap-4 text-muted small flex-wrap">
                        <span><i class="fas fa-lock me-1"></i>SSL Secured</span>
                        <span><i class="fas fa-shield-alt me-1"></i>GDPR Compliant</span>
                        <span><i class="fas fa-server me-1"></i>99.9% Uptime</span>
                        <span><i class="fas fa-headset me-1"></i>24/7 Support</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
function updatePreview() {
    const val = document.getElementById('subdomainInput').value.toLowerCase().replace(/[^a-z0-9-]/g, '');
    document.getElementById('urlPreview').innerHTML = 'Your school URL: <strong>' + (val || 'yourschool') + '.edumanagepro.com</strong>';
}
</script>
</body>
</html>
