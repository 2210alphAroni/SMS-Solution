@model List<SchoolManagementSystem.Models.FeeStructure>
@{
    ViewData["Title"] = "Fee Structures";
    var classes = ViewBag.Classes as List<SchoolManagementSystem.Models.Class> ?? new();
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-list-alt me-2 text-primary"></i>Fee Structures</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Fees">Fees</a></li>
            <li class="breadcrumb-item active">Structures</li>
        </ol></nav>
    </div>
</div>
<div class="row g-4">
    <div class="col-lg-8">
        @if (Model.Any())
        {
            foreach (var fs in Model)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h6 class="fw-bold mb-1">@fs.Name</h6>
                                <div class="text-muted small">@(classes.FirstOrDefault(c => c.Id == fs.ClassId)?.Name ?? "All Classes") &mdash; @fs.AcademicYear</div>
                            </div>
                            <div class="fw-bold text-primary fs-5">৳@fs.TotalAmount.ToString("N0")</div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>COMPONENT</th><th>AMOUNT</th><th>OPTIONAL</th></tr></thead>
                                <tbody>
                                    @foreach (var comp in fs.Components)
                                    {
                                        <tr>
                                            <td>@comp.Name</td>
                                            <td>৳@comp.Amount.ToString("N0")</td>
                                            <td>@(comp.IsOptional ? "Yes" : "No")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5 text-muted card"><div class="card-body">
                <i class="fas fa-list-alt fa-3x mb-3 d-block opacity-25"></i>
                <h5>No fee structures defined yet</h5>
            </div></div>
        }
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header"><i class="fas fa-plus me-2 text-primary"></i>Create Fee Structure</div>
            <div class="card-body">
                <form asp-controller="Fees" asp-action="CreateStructure" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3"><label class="form-label">Structure Name *</label>
                        <input name="Name" class="form-control" required />
                    </div>
                    <div class="mb-3"><label class="form-label">Class</label>
                        <select name="ClassId" class="form-select">
                            <option value="">All Classes</option>
                            @foreach (var c in classes) { <option value="@c.Id">@c.Name</option> }
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label">Academic Year</label>
                        <input name="AcademicYear" class="form-control" placeholder="e.g., 2025" />
                    </div>
                    <hr />
                    <div id="compsContainer">
                        <div class="comp-row row g-2 mb-2">
                            <div class="col-7"><input type="text" class="form-control form-control-sm" name="Components[0].Name" placeholder="Fee Name" /></div>
                            <div class="col-4"><input type="number" class="form-control form-control-sm comp-amount" name="Components[0].Amount" value="0" /></div>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mt-2">Save Structure</button>
                </form>
            </div>
        </div>
    </div>
</div>