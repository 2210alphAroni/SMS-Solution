@model SchoolManagementSystem.Models.FeePayment
@{
    ViewData["Title"] = "Fee Receipt";
    var student = ViewBag.Student as SchoolManagementSystem.Models.Student;
}
<div class="page-header d-print-none">
    <div>
        <h1><i class="fas fa-receipt me-2 text-primary"></i>Fee Receipt</h1>
    </div>
    <div class="d-flex gap-2">
        <a href="/Fees" class="btn btn-outline-secondary d-print-none"><i class="fas fa-arrow-left me-2"></i>Back</a>
        <button onclick="window.print()" class="btn btn-primary d-print-none"><i class="fas fa-print me-2"></i>Print Receipt</button>
    </div>
</div>

<div class="receipt-card">
    <div class="receipt-header">
        <i class="fas fa-graduation-cap fa-2x mb-2"></i>
        <h3 class="mb-1 fw-bold">@User.FindFirst("TenantName")?.Value</h3>
        <p class="mb-1 opacity-75">Fee Payment Receipt</p>
        <div class="d-flex justify-content-center gap-4 mt-3 opacity-90 small">
            <span><i class="fas fa-hashtag me-1"></i>Receipt: @Model.ReceiptNo</span>
            <span><i class="fas fa-calendar me-1"></i>@Model.PaymentDate.ToString("dd MMM yyyy")</span>
        </div>
    </div>
    <div class="receipt-body">
        @if (student != null)
        {
            <div class="row g-3 mb-4 p-3 rounded-3" style="background:var(--bg-body);">
                <div class="col-sm-6">
                    <div class="text-muted small mb-1">Student Name</div>
                    <div class="fw-bold">@student.FullName</div>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small mb-1">Admission No</div>
                    <div class="fw-bold">@student.AdmissionNo</div>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small mb-1">Class</div>
                    <div class="fw-bold">@student.ClassId @student.Section</div>
                </div>
                <div class="col-sm-6">
                    <div class="text-muted small mb-1">Month</div>
                    <div class="fw-bold">@Model.Month</div>
                </div>
            </div>
        }

        <div class="receipt-row"><span class="text-muted">Total Fee Amount</span><span class="fw-semibold">৳@Model.TotalAmount.ToString("N2")</span></div>
        @if (Model.DiscountAmount > 0)
        {
            <div class="receipt-row"><span class="text-muted">Discount</span><span class="text-success fw-semibold">- ৳@Model.DiscountAmount.ToString("N2")</span></div>
        }
        @if (Model.FineAmount > 0)
        {
            <div class="receipt-row"><span class="text-muted">Late Fine</span><span class="text-danger fw-semibold">+ ৳@Model.FineAmount.ToString("N2")</span></div>
        }
        <div class="receipt-row"><span class="text-muted">Payment Method</span><span>@Model.PaymentMethod</span></div>
        @if (!string.IsNullOrEmpty(Model.TransactionId))
        {
            <div class="receipt-row"><span class="text-muted">Transaction ID</span><span><code>@Model.TransactionId</code></span></div>
        }
        <div class="receipt-row"><span class="text-muted">Payment Status</span>
            <span class="badge @(Model.Status == "Paid" ? "bg-success" : Model.Status == "Partial" ? "bg-warning text-dark" : "bg-danger") fs-6">@Model.Status</span>
        </div>

        <div class="mt-4 p-3 rounded-3 border-2" style="border:2px dashed var(--primary);background:rgba(79,70,229,.04)">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">Amount Paid</div>
                    <div class="receipt-total">৳@Model.PaidAmount.ToString("N2")</div>
                </div>
                @if (Model.DueAmount > 0)
                {
                    <div class="text-end">
                        <div class="text-muted small">Balance Due</div>
                        <div class="fw-bold fs-5 text-danger">৳@Model.DueAmount.ToString("N2")</div>
                    </div>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Remarks))
        {
            <div class="mt-3 p-3 bg-light rounded-3">
                <div class="text-muted small mb-1">Remarks</div>
                <div>@Model.Remarks</div>
            </div>
        }

        <div class="mt-5 pt-4 border-top d-flex justify-content-between">
            <div class="text-center">
                <div style="height:40px;border-bottom:1px solid #000;min-width:150px;"></div>
                <div class="text-muted small mt-1">Student Signature</div>
            </div>
            <div class="text-center">
                <div style="height:40px;border-bottom:1px solid #000;min-width:150px;"></div>
                <div class="text-muted small mt-1">Authorized Signature</div>
            </div>
        </div>

        <div class="text-center mt-4 text-muted small">
            <i class="fas fa-check-circle text-success me-1"></i>This is a computer generated receipt.
            Generated on @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")
        </div>
    </div>
</div>

<style>
@@media print {
    .d-print-none { display: none !important; }
    body { background: white; }
    .receipt-card { box-shadow: none; border: 1px solid #ddd; max-width: 100%; }
    .page-content { padding: 0; }
}
</style>
