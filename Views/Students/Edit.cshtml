@model SchoolManagementSystem.Models.Student
@{
    ViewData["Title"] = "Edit Student";
    var classes = ViewBag.Classes as List<SchoolManagementSystem.Models.Class> ?? new();
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-user-edit me-2 text-primary"></i>Edit Student</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Students">Students</a></li>
            <li class="breadcrumb-item active">Edit - @Model.FullName</li>
        </ol></nav>
    </div>
</div>
<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TenantId" />
    <input type="hidden" asp-for="AdmissionNo" />
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-user me-2 text-primary"></i>Personal Information</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6"><label class="form-label">First Name *</label><input asp-for="FirstName" class="form-control" required /></div>
                        <div class="col-md-6"><label class="form-label">Last Name *</label><input asp-for="LastName" class="form-control" required /></div>
                        <div class="col-md-6"><label class="form-label">Email</label><input asp-for="Email" type="email" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Phone</label><input asp-for="Phone" class="form-control" /></div>
                        <div class="col-md-4"><label class="form-label">Date of Birth</label><input asp-for="DateOfBirth" type="date" class="form-control" /></div>
                        <div class="col-md-4"><label class="form-label">Gender</label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                        <div class="col-md-4"><label class="form-label">Blood Group</label>
                            <select asp-for="BloodGroup" class="form-select">
                                <option value="">-- Select --</option>
                                @foreach(var bg in new[]{"A+","A-","B+","B-","AB+","AB-","O+","O-"})
                                { <option value="@bg">@bg</option> }
                            </select>
                        </div>
                        <div class="col-md-6"><label class="form-label">Religion</label><input asp-for="Religion" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Nationality</label><input asp-for="Nationality" class="form-control" /></div>
                    </div>
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-graduation-cap me-2 text-primary"></i>Academic Information</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-5"><label class="form-label">Class *</label>
                            <select asp-for="ClassId" class="form-select" id="classSelect" required>
                                <option value="">-- Select Class --</option>
                                @foreach (var c in classes) { <option value="@c.Id" data-sections="@string.Join(",", c.Sections.Select(s => s.Name))">@c.Name</option> }
                            </select>
                        </div>
                        <div class="col-md-3"><label class="form-label">Section</label>
                            <select asp-for="Section" class="form-select" id="sectionSelect">
                                <option value="">-- Section --</option>
                            </select>
                        </div>
                        <div class="col-md-4"><label class="form-label">Roll No</label><input asp-for="RollNo" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Alumni">Alumni</option>
                                <option value="Transferred">Transferred</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header"><i class="fas fa-map-marker-alt me-2 text-primary"></i>Address</div>
                <div class="card-body">
                    <div class="mb-3"><label class="form-label">Present Address</label><textarea asp-for="Address.PresentAddress" class="form-control" rows="2"></textarea></div>
                    <div class="mb-3"><label class="form-label">Permanent Address</label><textarea asp-for="Address.PermanentAddress" class="form-control" rows="2"></textarea></div>
                    <div class="mb-3"><label class="form-label">City</label><input asp-for="Address.City" class="form-control" /></div>
                    <div class="mb-3"><label class="form-label">Country</label><input asp-for="Address.Country" class="form-control" /></div>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex gap-3 justify-content-end mt-2">
        <a href="/Students/@Model.Id" class="btn btn-outline-secondary"><i class="fas fa-times me-2"></i>Cancel</a>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
    </div>
</form>
<script>
document.getElementById('classSelect')?.addEventListener('change', function() {
    const opt = this.options[this.selectedIndex];
    const secs = (opt.getAttribute('data-sections') || '').split(',').filter(Boolean);
    const sel = document.getElementById('sectionSelect');
    sel.innerHTML = '<option value="">-- Section --</option>';
    secs.forEach(s => { const o = document.createElement('option'); o.value = s; o.textContent = 'Section ' + s; sel.appendChild(o); });
    sel.value = '@Model.Section';
});
document.getElementById('classSelect')?.dispatchEvent(new Event('change'));
</script>
