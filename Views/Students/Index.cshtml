@model List<SchoolManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Students";
    var classes = ViewBag.Classes as List<SchoolManagementSystem.Models.Class> ?? new();
}
<div class="page-header">
    <div>
        <h1><i class="fas fa-user-graduate me-2 text-primary"></i>Students</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li><li class="breadcrumb-item active">Students</li></ol></nav>
    </div>
    <div class="d-flex gap-2">
        <a href="/Students/Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Student</a>
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="fas fa-download me-1"></i>Export
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="#"><i class="fas fa-file-excel me-2 text-success"></i>Export to Excel</a></li>
                <li><a class="dropdown-item" href="#"><i class="fas fa-file-pdf me-2 text-danger"></i>Export to PDF</a></li>
            </ul>
        </div>
    </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon purple"><i class="fas fa-users"></i></div><div><div class="stat-value">@Model.Count</div><div class="stat-label">Shown</div></div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon green"><i class="fas fa-check-circle"></i></div><div><div class="stat-value">@Model.Count(s => s.Status == "Active")</div><div class="stat-label">Active</div></div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon orange"><i class="fas fa-male"></i></div><div><div class="stat-value">@Model.Count(s => s.Gender == "Male")</div><div class="stat-label">Male</div></div></div></div>
    <div class="col-sm-3"><div class="stat-card"><div class="stat-icon blue"><i class="fas fa-female"></i></div><div><div class="stat-value">@Model.Count(s => s.Gender == "Female")</div><div class="stat-label">Female</div></div></div></div>
</div>

<!-- Filters -->
<div class="table-card">
    <div class="table-header">
        <div class="d-flex gap-2 flex-wrap">
            <form method="get" class="d-flex gap-2 flex-wrap">
                <input name="search" value="@ViewBag.Search" class="form-control" style="width:220px;" placeholder="Search name, admission no..."/>
                <select name="classId" class="form-select" style="width:160px;">
                    <option value="">All Classes</option>
                    @foreach (var cls in classes) {
                        <option value="@cls.Id" selected="@(ViewBag.SelectedClass == cls.Id ? "selected" : null)">@cls.Name</option>
                    }
                </select>
                <select name="status" class="form-select" style="width:130px;">
                    <option value="">All Status</option>
                    <option value="Active" selected="@(ViewBag.SelectedStatus == "Active" ? "selected" : null)">Active</option>
                    <option value="Inactive" selected="@(ViewBag.SelectedStatus == "Inactive" ? "selected" : null)">Inactive</option>
                    <option value="Graduated" selected="@(ViewBag.SelectedStatus == "Graduated" ? "selected" : null)">Graduated</option>
                </select>
                <button type="submit" class="btn btn-primary"><i class="fas fa-search me-1"></i>Filter</button>
                <a href="/Students" class="btn btn-outline-secondary"><i class="fas fa-times me-1"></i>Clear</a>
            </form>
        </div>
        <div class="text-muted small">@Model.Count student(s) found</div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>STUDENT</th>
                        <th>ADMISSION NO</th>
                        <th>CLASS</th>
                        <th>CONTACT</th>
                        <th>GENDER</th>
                        <th>STATUS</th>
                        <th>ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        var cls = classes.FirstOrDefault(c => c.Id == student.ClassId);
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar" style="background:hue-rotate(@(Math.Abs(student.FirstName.GetHashCode()) % 360)deg) var(--primary)">
                                        @student.FirstName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@student.FullName</div>
                                        <div class="text-muted small">@student.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><code class="text-primary">@student.AdmissionNo</code></td>
                            <td>@(cls?.Name ?? "-") @(!string.IsNullOrEmpty(student.Section) ? $"({student.Section})" : "")</td>
                            <td>
                                <div class="small">@student.Phone</div>
                            </td>
                            <td><span class="badge bg-light text-dark">@student.Gender</span></td>
                            <td>
                                <span class="badge badge-status-@student.Status.ToLower()">@student.Status</span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/Students/Details/@student.Id" class="btn btn-sm btn-outline-primary btn-icon" title="View" data-bs-toggle="tooltip">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="/Students/Edit/@student.Id" class="btn btn-sm btn-outline-secondary btn-icon" title="Edit" data-bs-toggle="tooltip">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-controller="Students" asp-action="Delete" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@student.Id"/>
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-icon" title="Delete" data-bs-toggle="tooltip" data-confirm="Delete student '@student.FullName'?">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-user-graduate fa-3x mb-3 d-block opacity-25"></i>
            <h5>No students found</h5>
            <p>@(string.IsNullOrEmpty(ViewBag.Search as string) ? "Start by adding your first student." : "No students match your search criteria.")</p>
            <a href="/Students/Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add First Student</a>
        </div>
    }
</div>
